# =========================================================
# Frontend public env
# Aman dipakai di browser selama RLS Supabase sudah benar.
# Untuk Vite/React gunakan prefix VITE_.
# Untuk project vanilla sekarang, nilai ini bisa dipakai saat nanti
# konfigurasi Supabase client dipindahkan ke module/build tool.
# =========================================================

VITE_APP_URL=http://localhost:5173
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Auth redirect target untuk development lokal.
VITE_AUTH_REDIRECT_URL=http://localhost:5173

# Storage bucket untuk foto profil.
VITE_SUPABASE_AVATAR_BUCKET=avatars

# Backend API untuk endpoint seperti moderasi username.
# Development lokal: http://localhost:3000
# Production Vercel + Railway: https://nama-service.up.railway.app
VITE_API_BASE_URL=http://localhost:3000

# Realtime channel naming.
VITE_REALTIME_LOBBY_CHANNEL=lobby
VITE_REALTIME_ROOM_PREFIX=room
VITE_REALTIME_MATCH_PREFIX=match

# Mode realtime untuk tahap refactor ini.
# websocket = tetap memakai server.js lokal untuk multiplayer.
# supabase = gunakan Supabase Realtime (tanpa backend WS).
# disabled = frontend tetap jalan, multiplayer dinonaktifkan sementara.
VITE_REALTIME_MODE=websocket

# Moderasi username:
# auto = pakai API saat localhost atau VITE_API_BASE_URL tersedia
# api = selalu pakai API moderasi username
# disabled/local = blokir perubahan username karena AI tidak tersedia
VITE_MODERATION_MODE=auto
VITE_MODERATION_TIMEOUT_MS=15000
VITE_LOCAL_BACKEND_URL=http://localhost:3000
VITE_WS_URL=/ws

# Game config yang boleh diketahui client.
VITE_GAME_DURATION_SECONDS=60
VITE_MAX_ROOM_PLAYERS=6
VITE_MAX_ACTIVE_MOLES=3


# =========================================================
# Local Node dev server
# Dipakai kalau masih menjalankan server.js lokal.
# =========================================================

PORT=3000


# =========================================================
# Supabase Edge Function / backend-only secrets
# JANGAN taruh variable ini di frontend atau expose ke browser.
# Simpan di Supabase Edge Function Secrets / Vercel Server env.
# =========================================================

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Untuk moderasi username menggunakan Gemini.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=
GEMINI_REQUEST_TIMEOUT_MS=10000
GEMINI_UNAVAILABLE_COOLDOWN_MS=45000
USERNAME_MODERATION_CACHE_TTL_MS=600000


# =========================================================
# Google OAuth
# Client secret disimpan di Supabase Dashboard, bukan frontend.
# Bagian ini hanya catatan jika kamu butuh dokumentasi env lokal.
# =========================================================

GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
